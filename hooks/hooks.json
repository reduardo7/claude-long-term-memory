{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_pre_compact_reminder.py\"",
            "timeout": 5000,
            "statusMessage": "Saving memory before compact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_post_compact_reminder.py\"",
            "timeout": 5000,
            "statusMessage": "Reloading base docs after compact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_pre_agent_reminder.py\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_stop_reminder.py\"",
            "timeout": 5000,
            "statusMessage": "Memory reminder"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_search_reminder.py\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/memory_log_reminder.py\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
